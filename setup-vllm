# configurazione attuale che non avvia. molteplici errori 
version: "3.9"

services:
  vllm:
    image: vllm/vllm-openai:v0.4.2

    container_name: vllm-server
    runtime: nvidia
    restart: unless-stopped

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 6
              capabilities: [gpu]

    environment:
      - NVIDIA_VISIBLE_DEVICES=all
      - HF_HOME=/models
      - TRANSFORMERS_CACHE=/models
      - NCCL_P2P_DISABLE=1
      - NCCL_IB_DISABLE=1
      - PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

    volumes:
      - ./data:/root/.cache/huggingface
      - /srv/ai1/vllm-server/modelli:/models

    ports:
      - "8000:8000"

    command: >
      --model Qwen/Qwen2.5-32B-Instruct **voglio massimo possibile**
      --tensor-parallel-size 5
      --max-model-len 32768 **voglio massimo possibile, minimo 256k**
      --gpu-memory-utilization 0.90
      --trust-remote-code
      --enable-prefix-caching
