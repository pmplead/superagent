# capitolo 1.
```
version: "3.9"

services:
  ollama:
    image: ollama/ollama:latest
    container_name: hermesollama
    restart: unless-stopped

    ports:
      - "11435:11434"

    environment:
      # networking
      - OLLAMA_HOST=0.0.0.0
      - OLLAMA_ORIGINS=http://xxx,http://xxx,http://xxx

      # parallelismo (realistico per la tua CPU)
      #- OLLAMA_NUM_PARALLEL=1
      - OLLAMA_MAX_LOADED_MODELS=1
      # Usa tutte e 6 le GPU, ma con split conservativo
      #- OLLAMA_NUM_GPU=6
      - OLLAMA_GPU_SPLIT=2,2,2
      - OLLAMA_MAX_QUEUE=2

      # GPU
      - CUDA_VISIBLE_DEVICES=0,1,2,3,4,5
      #- NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5
      #- NVIDIA_DRIVER_CAPABILITIES=compute,utility
      - OLLAMA_KEEP_ALIVE=10h
      - OLLAMA_LOAD_TIMEOUT=900

    volumes:
      - /srv/ai1/ollamaebasta:/root/.ollama
    deploy:
      resources:
        reservations:
          devices:
            - capabilities: [gpu]
volumes:
  ollama:
```
